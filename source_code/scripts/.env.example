# Copy to `.env`, fill in, then `set -a && source ./.env && set +a`.

# Entry node
PROJECT_ROOT=/path/to/as2org_pipeline
BASE_DIR=/path/to/pipeline/data/run
REMOTE_CRAWL_HOST=user@remote-crawl-host
LOCAL_CRAWL_HOST=user@local-crawl-host
ENTRY_STAGE_DIR=/path/to/entry/stage

# Remote NER node
REMOTE_NER_HOME=/path/to/remote_ner_server
NER_HOME=/path/to/remote_ner_server
NER_WORK_DIR=/path/to/ner/workspace
NER_VENV=/path/to/ner_env
ENTRY_HOST=user@entry-host

# Remote vLLM node
REMOTE_LLM_HOME=/path/to/remote_llm_server

# WHOIS data sources
IRR_SRC_DIR=/path/to/irrs/compressed
WHOIS_IPS_SRC_DIR=/path/to/whois-ips
